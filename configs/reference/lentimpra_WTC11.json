{
  "_comment": "Normalized config schema for LentiMPRA WTC11 training.",
  "data": {
    "input_tsv": null,
    "sequence_length": null,
    "construct_mode": "promoter_barcode",
    "batch_size": 32,
    "reverse_complement": true,
    "rc_prob": 0.5,
    "random_shift": true,
    "shift_prob": 0.5,
    "max_shift": 15,
    "subset_frac": 1.0,
    "num_workers": 0,
    "pin_memory": false
  },
  "head": {
    "pooling_type": "flatten",
    "hidden_sizes": [1024],
    "dropout": 0.0,
    "activation": "relu"
  },
  "optim": {
    "optimizer": "adam",
    "learning_rate": 1e-03,
    "weight_decay": 1e-06,
    "lr_scheduler": "constant",
    "gradient_accumulation_steps": 1,
    "gradient_clip": null
  },
  "stage": {
    "num_epochs": 100,
    "early_stopping_patience": 5,
    "val_evals_per_epoch": 4,
    "second_stage_lr": 1e-05,
    "second_stage_epochs": 50,
    "resume_from_stage2": false
  },
  "checkpoint": {
    "pretrained_weights": null,
    "checkpoint_dir": "./results/mpra_WTC11",
    "save_mode": "minimal"
  },
  "logging": {
    "use_wandb": true,
    "wandb_project": "alphagenome-mpra",
    "wandb_name": "mpra-WTC11"
  },
  "runtime": {
    "device": null,
    "use_amp": false,
    "seed": 42
  }
}
