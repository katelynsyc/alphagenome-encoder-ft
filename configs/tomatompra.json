  "stage": {
    "num_epochs": 200,
    "early_stopping_patience": 10,
    "val_evals_per_epoch": 1,
    "second_stage_lr": null,
    "second_stage_epochs": 10,
    "resume_from_stage2": false
  },
  "checkpoint": {
    "pretrained_weights": null,
    "checkpoint_dir": "./results/deeptomato",
    "save_mode": "minimal"
  },
  "logging": {
    "use_wandb": false,
    "wandb_project": "plantmpra",
    "wandb_name": "deeptomato"
  },
  "runtime": {
    "device": null,
    "use_amp": false,
    "seed": 42
  }
