{
  "_comment": "TrainConfig-compatible config for DeepTOMATO tomato MPRA training.",
  "_model_architecture": {
    "input_shape": [4, 160],
    "conv_layers": [
      {"out_channels": 256, "kernel_size": 7, "activation": "relu", "padding": "same"},
      {"out_channels": 128, "kernel_size": 5, "activation": "relu", "padding": "same"},
      {"out_channels":  64, "kernel_size": 3, "activation": "relu", "padding": "same"}
    ],
    "pooling_size": 2,
    "batch_normalization": true,
    "output_activation": "linear",
    "_note_data": "encoding=one_hot, nucleotide_order=[A,C,G,T], skip_character=N, input_column=Sequence, target_columns=[Leaf_activity, MG_activity,  Br_activity, RR_activity]"
  },
  "data": {
    "input_tsv": null,
    "sequence_length": 160,
    "batch_size": 64,
    "barcode_min": 10,
    "barcode_min_eval": 10,
    "reverse_complement": false,
    "rc_prob": 0.5,
    "random_shift": false,
    "shift_prob": 0.5,
    "max_shift": 20,
    "subset_frac": 1.0,
    "num_workers": 0,
    "pin_memory": false,
    "val_chroms": ["ch03"],
    "test_chroms": ["ch06"],
    "weight_scheme": "log",
    "split_mode": "random",
